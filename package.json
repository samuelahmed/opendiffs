{
  "name": "opendiffs",
  "version": "0.1.4",
  "description": "AI-powered code review from the terminal",
  "bin": {
    "opendiffs": "./out/src/cli.js"
  },
  "type": "module",
  "main": "./out/src/cli.js",
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "dev": "tsc -p ./ && node out/src/cli.js",
    "test": "tsc -p ./ && node --test out/tests/*.test.js"
  },
  "keywords": [
    "code-review",
    "ai",
    "claude",
    "codex",
    "git",
    "diff",
    "cli"
  ],
  "author": "Sam Duval",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/samuelahmed/opendiffs"
  },
  "files": [
    "out/src/*.js",
    "out/src/*.js.map",
    ".opendiffs/prompt.md",
    ".opendiffs/config.json"
  ],
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "marked": "^12.0.2",
    "marked-terminal": "^7.3.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
